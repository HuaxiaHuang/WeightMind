# ════════════════════════════════════════════════════════
#  LLM 配置（支持 OpenAI 兼容接口，也可用本地 Ollama）
# ════════════════════════════════════════════════════════
LLM_PROVIDER=openai
# 🔴 请在此填入真实的 API Key
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus-2025-07-28
LLM_SUMMARY_MODEL=qwen-plus-2025-07-28
LLM_TEMPERATURE=0.1

# ════════════════════════════════════════════════════════
#  Embedding & Reranker（本地模型相对路径）
# ════════════════════════════════════════════════════════
# 🟢 已修改为相对路径，适配云端 Docker 环境
EMBEDDING_MODEL_PATH=./models/bge-m3
RERANKER_MODEL_PATH=./models/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ════════════════════════════════════════════════════════
#  数据库连接 (Docker Compose 网络配置)
# ════════════════════════════════════════════════════════
POSTGRES_USER=sci_rag
# 建议在真实部署时修改此密码
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=sci_rag_db
# 🟢 已将 localhost 改为 postgres (对应 docker-compose 服务名)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sci_rag:your_db_password_here@postgres:5432/sci_rag_db

# ════════════════════════════════════════════════════════
#  Qdrant 向量库与网络代理
# ════════════════════════════════════════════════════════
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,dashscope.aliyuncs.com,postgres,redis,qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ════════════════════════════════════════════════════════
#  Redis / Celery (Docker Compose 网络配置)
# ════════════════════════════════════════════════════════
# 🟢 已将 localhost 改为 redis (对应 docker-compose 服务名)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ════════════════════════════════════════════════════════
#  🚀 云端解析引擎 (TextIn & LlamaParse)
# ════════════════════════════════════════════════════════
# 🔴 请在此填入真实的 App ID 和 Secret Code
TEXTIN_APP_ID=your_textin_app_id_here
TEXTIN_SECRET_CODE=your_textin_secret_code_here

# 🔴 请在此填入真实的 LlamaCloud API 密钥
LLAMA_CLOUD_API_KEY=your_llamacloud_api_key_here

# 解析模式：eco (节能优先TextIn，失败转Llama) / performance (双轨并发，择优录取)
PARSE_MODE=eco

# ════════════════════════════════════════════════════════
#  文件存储路径（相对路径，映射到 Docker 内部）
# ════════════════════════════════════════════════════════
# 🟢 已修改为相对路径
DATA_ROOT=./data
RAW_DATA_DIR=./data/raw
TEMP_DIR=./data/temp
MAX_UPLOAD_SIZE_MB=100

# ════════════════════════════════════════════════════════
#  RAG 参数
# ════════════════════════════════════════════════════════
CHILD_CHUNK_SIZE=128
PARENT_CHUNK_SIZE=512
CHUNK_OVERLAP=20
TOP_K_RETRIEVE=10
TOP_K_RERANK=5
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# ════════════════════════════════════════════════════════
#  应用配置
# ════════════════════════════════════════════════════════
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO