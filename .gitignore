# ==========================================
# 🛑 核心机密与配置（绝对不能提交）
# ==========================================
.env
# 注意：.env.example 必须提交，所以这里不忽略它

# ==========================================
# 📦 数据与数据库（防止庞大且敏感的数据上云）
# ==========================================
# 忽略 data 目录下的所有文件和文件夹
data/*
# 但保留 data 目录本身（可选，如果你想在 GitHub 上保留这个空文件夹结构）
!data/.gitkeep

# 忽略 Docker 可能在根目录生成的默认命名数据卷（保险起见）
postgres_data/
qdrant_data/
redis_data/
temp_pdfs/

# ==========================================
# 🧠 AI 模型与缓存（体积极大）
# ==========================================
models/
.cache/
huggingface_cache/

# ==========================================
# 🐍 Python 虚拟环境与字节码
# ==========================================
Env/
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/
*.egg

# ==========================================
# 📝 日志与测试
# ==========================================
*.log
logs/
.pytest_cache/
.coverage
htmlcov/

# ==========================================
# 💻 操作系统与 IDE
# ==========================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo